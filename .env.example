FORMARE_BOT_CONTACT_EMAIL=pricing@example.com
# Local development: omit DATABASE_URL to use data/database/prices.db.
# Production: use the Supabase pooled connection string with sslmode=require.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:6543/postgres?sslmode=require
FORMARE_DASHBOARD_PASSWORD=change-this-client-password
FORMARE_ADMIN_PASSWORD=change-this-admin-password
